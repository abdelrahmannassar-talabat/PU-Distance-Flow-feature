WITH data AS 
(
  WITH undispatches AS 
  (
    SELECT
      order id,
      COUNT(state) AS total undispatches
    FROM `tlb-data-prod.data platform.fct logistics delivery transition` dt
    WHERE dt.country code = 'eg'
      AND created date BETWEEN '2025-10-01' AND '2026-01-31'
      AND (
        (created date BETWEEN '2025-10-01' AND '2025-11-30'
        AND action reason = 'System - Distance to pickup/dropoff too far - not willing to proceed')
        OR
        (created date BETWEEN '2025-12-01' AND '2026-01-31'
        AND LOWER(action reason) IN ('inspection issue', 'distance pickup issue'))
      )
    GROUP BY 1
  ),

  contacts AS 
  (
    SELECT DISTINCT order id
    FROM `tlb-data-prod.data platform.fct contact` c
    WHERE delivery type != 'Non-order related'
      AND stakeholder id = 1
      AND DATE(c.created at time local) BETWEEN '2025-10-01' AND '2026-01-31'
  ),

  orders AS 
  (
    SELECT
      o.order id,
      CASE
        WHEN DATE(o.created at, o.timezone) BETWEEN '2025-10-01' AND '2025-11-30'
        THEN '2 Months Before' ELSE '2 Months After'
      END AS Period,
      o.actual delivery time / 60 AS DT,
      o.rider accepting time / 60 AS RAT,
      CASE
        WHEN (o.actual delivery time / 60) - (o.promised delivery time / 60) > 10
        THEN 1 ELSE 0
      END AS is late,

      CASE 
        WHEN order delay IS NOT NULL AND actual delivery time IS NOT NULL AND 
        ((o.actual delivery time/60) >= (TIMESTAMP DIFF(promised delivery at upper bound,created at,SECOND)/60) + 10) 
        THEN 1 ELSE 0 
      END AS is Late Orders Upper pdt 10,   

      CASE 
        WHEN order delay IS NOT NULL AND actual delivery time IS NOT NULL AND 
        ((o.actual delivery time/60) >= (TIMESTAMP DIFF(promised delivery at upper bound,created at,SECOND)/60) + 10) 
        THEN 1 ELSE 0 
      END AS is Late Orders Upper pdt,      

      CASE 
        WHEN order delay IS NOT NULL AND actual delivery time IS NOT NULL AND 
        ((o.actual delivery time/60) >= (TIMESTAMP DIFF(promised delivery at upper bound,created at,SECOND)/60) + 10) 
        AND v.vertical = 'food' 
        THEN 1 ELSE 0 
      END AS is Late Orders Upper pdt food, 

      CASE WHEN order delay IS NOT NULL AND actual delivery time IS NOT NULL THEN order id END AS Upper pdt orders,

      CASE WHEN order delay IS NOT NULL AND actual delivery time IS NOT NULL AND o.vertical type = 'food' THEN order id END AS Upper pdt food orders

    FROM `tlb-data-prod.data platform.fct logistics order` o
    LEFT JOIN `tlb-data-prod.data platform.dim vendor` v
    on o.vendor id = v.vendor id and v.is active
    WHERE o.country code = 'eg'
      AND DATE(o.created at, o.timezone) BETWEEN '2025-10-01' AND '2026-01-31'
      AND o.order status = 'completed'
  )

  SELECT
    Period,
    COUNT(DISTINCT o.order id)                                          AS Total Orders,
    COUNT(DISTINCT u.order id)                                          AS Problematic Orders,
    ROUND(COUNT(DISTINCT u.order id) / COUNT(DISTINCT o.order id), 4)   AS Share From Overall,
    AVG(u.total undispatches)                                           AS Undispatches Per Order,

    -- Problematic
    AVG(CASE WHEN u.order id IS NOT NULL THEN DT END)                   AS Problematic Avg DT,
    AVG(CASE WHEN u.order id IS NOT NULL THEN RAT END)                  AS Problematic Avg RAT,

    ROUND(SAFE DIVIDE(
      SUM(CASE WHEN u.order id IS NOT NULL THEN is late END),
      COUNT(CASE WHEN u.order id IS NOT NULL THEN upper pdt orders END)
    ), 4)                                                               AS Problematic Late perc,

    ROUND(SAFE DIVIDE(
      SUM(CASE WHEN u.order id IS NOT NULL THEN is Late Orders Upper pdt END),
      COUNT(CASE WHEN u.order id IS NOT NULL THEN upper pdt orders END)
    ), 4)                                                               AS Problematic Late upper pdt perc,

    ROUND(SAFE DIVIDE(
      SUM(CASE WHEN u.order id IS NOT NULL THEN is Late Orders Upper pdt 10 END),
      COUNT(CASE WHEN u.order id IS NOT NULL THEN upper pdt orders END)
    ), 4)                                                               AS Problematic Late upper pdt 10 perc,

    ROUND(SAFE DIVIDE(
      SUM(CASE WHEN u.order id IS NOT NULL THEN is Late Orders Upper pdt food END),
      COUNT(CASE WHEN u.order id IS NOT NULL THEN upper pdt food orders END)
    ), 4)                                                               AS Problematic Late upper pdt food perc,

    ROUND(SAFE DIVIDE(
      COUNT(DISTINCT CASE WHEN u.order id IS NOT NULL THEN c.order id END),
      COUNT(DISTINCT CASE WHEN u.order id IS NOT NULL THEN o.order id END)
    ), 4)                                                               AS Problematic Contact Rate,

    -- Normal
    AVG(CASE WHEN u.order id IS NULL THEN DT END)                       AS Normal Avg DT,
    AVG(CASE WHEN u.order id IS NULL THEN RAT END)                      AS Normal Avg RAT,

    ROUND(SAFE DIVIDE(
      SUM(CASE WHEN u.order id IS NULL THEN is late END),
      COUNT(CASE WHEN u.order id IS NULL THEN upper pdt orders END)
    ), 4)                                                               AS Normal Late Rate,

    ROUND(SAFE DIVIDE(
      SUM(CASE WHEN u.order id IS NULL THEN is Late Orders Upper pdt END),
      COUNT(CASE WHEN u.order id IS NULL THEN upper pdt orders END)
    ), 4)                                                               AS Normal Late upper pdt perc,

    ROUND(SAFE DIVIDE(
      SUM(CASE WHEN u.order id IS NULL THEN is Late Orders Upper pdt 10 END),
      COUNT(CASE WHEN u.order id IS NULL THEN upper pdt orders END)
    ), 4)                                                               AS Normal Late upper pdt 10 perc,

    ROUND(SAFE DIVIDE(
      SUM(CASE WHEN u.order id IS NULL THEN is Late Orders Upper pdt food END),
      COUNT(CASE WHEN u.order id IS NULL THEN upper pdt food orders END)
    ), 4)                                                               AS Normal Late upper pdt food perc,  -- ✅ fixed alias

    ROUND(SAFE DIVIDE(
      COUNT(DISTINCT CASE WHEN u.order id IS NULL THEN c.order id END),
      COUNT(DISTINCT CASE WHEN u.order id IS NULL THEN o.order id END)
    ), 4)                                                               AS Normal Contact Rate

  FROM orders o
  LEFT JOIN undispatches u ON o.order id = u.order id
  LEFT JOIN contacts c     ON c.order id = CAST(o.order id AS STRING)
  GROUP BY 1
  ORDER BY Period
),

overall AS 
(
  SELECT 'Overall Metrics' AS Section, 'Total Orders' AS Metric,
    MAX(CASE WHEN Period = '2 Months Before' THEN Total Orders END) AS Before,
    MAX(CASE WHEN Period = '2 Months After'  THEN Total Orders END) AS After
  FROM data

  UNION ALL SELECT 'Overall Metrics', 'Problematic Orders',
    MAX(CASE WHEN Period = '2 Months Before' THEN Problematic Orders END),
    MAX(CASE WHEN Period = '2 Months After'  THEN Problematic Orders END)
  FROM data

  UNION ALL SELECT 'Overall Metrics', 'Share From Overall',
    MAX(CASE WHEN Period = '2 Months Before' THEN Share From Overall END),
    MAX(CASE WHEN Period = '2 Months After'  THEN Share From Overall END)
  FROM data

  UNION ALL SELECT 'Overall Metrics', 'Undispatches Per Order',
    MAX(CASE WHEN Period = '2 Months Before' THEN Undispatches Per Order END),
    MAX(CASE WHEN Period = '2 Months After'  THEN Undispatches Per Order END)
  FROM data
),

benchmarks AS 
(
  SELECT 'Benchmark Metrics' AS Section, 'Problematic Avg DT' AS Metric,
    MAX(CASE WHEN Period = '2 Months Before' THEN Problematic Avg DT END) AS Before,
    MAX(CASE WHEN Period = '2 Months After'  THEN Problematic Avg DT END) AS After
  FROM data

  UNION ALL SELECT 'Benchmark Metrics', 'Problematic Avg RAT',
    MAX(CASE WHEN Period = '2 Months Before' THEN Problematic Avg RAT END),
    MAX(CASE WHEN Period = '2 Months After'  THEN Problematic Avg RAT END)
  FROM data

  UNION ALL SELECT 'Benchmark Metrics', 'Problematic Late %',
    MAX(CASE WHEN Period = '2 Months Before' THEN Problematic Late perc END),
    MAX(CASE WHEN Period = '2 Months After'  THEN Problematic Late perc END)
  FROM data

  UNION ALL SELECT 'Benchmark Metrics', 'Problematic Late Upper pdt %',
    MAX(CASE WHEN Period = '2 Months Before' THEN Problematic Late upper pdt perc END),
    MAX(CASE WHEN Period = '2 Months After'  THEN Problematic Late upper pdt perc END)
  FROM data

  UNION ALL SELECT 'Benchmark Metrics', 'Problematic Late Upper pdt +10 %',
    MAX(CASE WHEN Period = '2 Months Before' THEN Problematic Late upper pdt 10 perc END),
    MAX(CASE WHEN Period = '2 Months After'  THEN Problematic Late upper pdt 10 perc END)
  FROM data

  UNION ALL SELECT 'Benchmark Metrics', 'Problematic Late Upper pdt Food +10 %',
    MAX(CASE WHEN Period = '2 Months Before' THEN Problematic Late upper pdt food perc END),
    MAX(CASE WHEN Period = '2 Months After'  THEN Problematic Late upper pdt food perc END)
  FROM data

  UNION ALL SELECT 'Benchmark Metrics', 'Problematic Contact Rate',
    MAX(CASE WHEN Period = '2 Months Before' THEN Problematic Contact Rate END),
    MAX(CASE WHEN Period = '2 Months After'  THEN Problematic Contact Rate END)
  FROM data

  UNION ALL SELECT 'Benchmark Metrics', 'Normal Avg DT',
    MAX(CASE WHEN Period = '2 Months Before' THEN Normal Avg DT END),
    MAX(CASE WHEN Period = '2 Months After'  THEN Normal Avg DT END)
  FROM data

  UNION ALL SELECT 'Benchmark Metrics', 'Normal Avg RAT',
    MAX(CASE WHEN Period = '2 Months Before' THEN Normal Avg RAT END),
    MAX(CASE WHEN Period = '2 Months After'  THEN Normal Avg RAT END)
  FROM data

  UNION ALL SELECT 'Benchmark Metrics', 'Normal Late %',
    MAX(CASE WHEN Period = '2 Months Before' THEN Normal Late Rate END),
    MAX(CASE WHEN Period = '2 Months After'  THEN Normal Late Rate END)
  FROM data

  UNION ALL SELECT 'Benchmark Metrics', 'Normal Late Upper pdt %',
    MAX(CASE WHEN Period = '2 Months Before' THEN Normal Late upper pdt perc END),
    MAX(CASE WHEN Period = '2 Months After'  THEN Normal Late upper pdt perc END)
  FROM data

  UNION ALL SELECT 'Benchmark Metrics', 'Normal Late Upper pdt +10 %',
    MAX(CASE WHEN Period = '2 Months Before' THEN Normal Late upper pdt 10 perc END),
    MAX(CASE WHEN Period = '2 Months After'  THEN Normal Late upper pdt 10 perc END)
  FROM data

  UNION ALL SELECT 'Benchmark Metrics', 'Normal Late Upper pdt Food %',       
    MAX(CASE WHEN Period = '2 Months Before' THEN Normal Late upper pdt food perc END),
    MAX(CASE WHEN Period = '2 Months After'  THEN Normal Late upper pdt food perc END)
  FROM data

  UNION ALL SELECT 'Benchmark Metrics', 'Normal Contact Rate',
    MAX(CASE WHEN Period = '2 Months Before' THEN Normal Contact Rate END),
    MAX(CASE WHEN Period = '2 Months After'  THEN Normal Contact Rate END)
  FROM data
)

SELECT * FROM overall
UNION ALL
SELECT * FROM benchmarks
ORDER BY Section, Metric;
